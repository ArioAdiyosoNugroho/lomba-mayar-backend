APP_NAME="Forest Guardian"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-api.up.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (Supabase)
DB_CONNECTION=pgsql
DB_HOST=db.XXXXXXXX.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=YOUR_SUPABASE_PASSWORD

# Or MySQL on Railway:
# DB_CONNECTION=mysql
# DB_HOST=containers-us-west-XXX.railway.app
# DB_PORT=XXXXX
# DB_DATABASE=railway
# DB_USERNAME=root
# DB_PASSWORD=XXXXXX

# File Storage — use 'public' for hackathon, 's3' for production
FILESYSTEM_DISK=public

# If using S3 / Supabase Storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=forest-guardian
# AWS_URL=https://your-bucket.s3.amazonaws.com

# Sanctum
SANCTUM_STATEFUL_DOMAINS=your-frontend.vercel.app,localhost:5173

# CORS
FRONTEND_URL=https://your-frontend.vercel.app

# Mayar Payment Gateway
MAYAR_API_KEY=sk_live_XXXXXXXXXXXXXXXXXX
MAYAR_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXX

# Rate limiting (requests per minute for report creation)
REPORT_RATE_LIMIT=5
